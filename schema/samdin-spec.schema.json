{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mbarlow/samdin/schema/samdin-spec.schema.json",
  "title": "Samdin Spec",
  "description": "A Samdin scene/model spec. Structure + enums are enforced here; per-type param counts, parent resolution, and CSG wiring stay in cli/validate-spec.cjs.",
  "type": "object",
  "required": ["name"],
  "oneOf": [
    { "required": ["parts"] },
    { "properties": { "type": { "const": "csg" } }, "required": ["type", "shapes", "operations"] }
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "root": { "type": "string" },
    "type": { "enum": ["csg"] },
    "parts": { "type": "array", "items": { "$ref": "#/definitions/part" } },
    "modules": {
      "oneOf": [
        { "type": "array", "items": { "$ref": "#/definitions/module" } },
        { "type": "object", "additionalProperties": { "$ref": "#/definitions/module" } }
      ]
    },
    "lintIgnore": { "$ref": "#/definitions/lintIgnore" },
    "scene": { "$ref": "#/definitions/scene" },
    "shapes": { "type": "object", "additionalProperties": { "$ref": "#/definitions/csgShape" } },
    "operations": { "type": "array", "items": { "$ref": "#/definitions/csgOperation" } },
    "output": { "type": "string" },
    "outputs": { "type": "array", "items": { "type": "object" } },
    "material": { "$ref": "#/definitions/material" },
    "animations": { "type": "object" },
    "clips": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/animationClip" }
    }
  },
  "definitions": {
    "vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "keyframe": {
      "type": "array",
      "items": [
        { "type": "number", "minimum": 0 },
        { "$ref": "#/definitions/vec3" }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "animationClip": {
      "type": "object",
      "required": ["tracks"],
      "properties": {
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "instances": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "tracks": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "properties": {
              "rotation": { "type": "array", "items": { "$ref": "#/definitions/keyframe" }, "minItems": 2 },
              "position": { "type": "array", "items": { "$ref": "#/definitions/keyframe" }, "minItems": 2 }
            },
            "additionalProperties": false,
            "anyOf": [{ "required": ["rotation"] }, { "required": ["position"] }]
          }
        }
      },
      "additionalProperties": false
    },
    "lintIgnore": {
      "type": "array",
      "items": {
        "enum": ["all", "zero-dimension", "scene-block", "camera-preset", "lighting-preset",
          "lighting-environment", "tonemapping", "metal-no-env", "emissive-budget",
          "breakup", "clone-read", "ground-contact"]
      }
    },
    "primitiveType": {
      "enum": [
        "box", "cylinder", "sphere", "cone", "torus", "capsule", "roundedBox", "plane",
        "group", "prefab", "module", "csg", "loft", "polyMesh", "region",
        "tetrahedron", "octahedron", "dodecahedron", "icosahedron", "prism", "pyramid",
        "wedge", "tube", "ring", "stairs", "arch", "lathe", "extrudePath", "cable",
        "catenary", "helix", "rock", "canopy",
        "pointLight", "spotLight", "areaLight",
        "ibeam", "lbeam", "tbeam", "channel", "hbeam", "angle", "hollowBox", "hollowCylinder",
        "pipeFlange", "elbow", "bracket", "gear", "cross", "frame", "windowFrame", "dome",
        "hexNut", "countersunk", "keyhole", "halfTorus", "sphereSlab", "notchedCylinder",
        "steppedPyramid", "boxSphereIntersect", "cylinderIntersect", "swissCheese"
      ]
    },
    "part": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/definitions/primitiveType" },
        "params": { "type": "array" },
        "material": { "$ref": "#/definitions/material" },
        "position": { "$ref": "#/definitions/vec3" },
        "rotation": { "$ref": "#/definitions/vec3" },
        "scale": {
          "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/vec3" }]
        },
        "parent": { "type": "string" },
        "pivot": { "type": "string" },
        "children": { "type": "array", "items": { "$ref": "#/definitions/part" } },
        "category": { "type": "string" },
        "flipNormals": { "type": "boolean" },
        "castShadow": { "type": "boolean" },
        "lintIgnore": { "$ref": "#/definitions/lintIgnore" },
        "modifiers": { "$ref": "#/definitions/modifiers" },
        "src": { "type": "string" },
        "module": { "type": "string" },
        "ref": { "type": "string" },
        "regionType": { "type": "string" },
        "bounds": {},
        "seed": { "type": "number" },
        "options": { "type": "object" },
        "shapes": { "type": "object" },
        "operations": { "type": "array" },
        "output": { "type": "string" },
        "outputs": { "type": "array" },
        "polyMesh": { "$ref": "#/definitions/polyMesh" }
      },
      "additionalProperties": true
    },
    "module": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" },
        "parts": { "type": "array", "items": { "$ref": "#/definitions/part" } }
      }
    },
    "polyMesh": {
      "type": "object",
      "properties": {
        "base": {
          "type": "object",
          "properties": {
            "type": { "enum": ["cube", "mesh"] },
            "size": { "$ref": "#/definitions/vec3" },
            "center": { "$ref": "#/definitions/vec3" },
            "vertices": { "type": "array", "items": { "$ref": "#/definitions/vec3" } },
            "faces": { "type": "array" }
          },
          "additionalProperties": true
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["op"],
            "properties": {
              "op": { "enum": ["select", "extrude", "inset", "translate", "scale", "rotate"] }
            },
            "additionalProperties": true
          }
        },
        "modifiers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["mirror"] },
              "axis": { "enum": ["x", "y", "z"] },
              "threshold": { "type": "number" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "modifiers": {
      "type": "object",
      "properties": {
        "array": {
          "type": "object",
          "properties": {
            "count": { "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/vec3" }] },
            "offset": { "$ref": "#/definitions/vec3" }
          }
        },
        "mirror": {
          "type": "object",
          "properties": {
            "x": { "type": "boolean" }, "y": { "type": "boolean" }, "z": { "type": "boolean" },
            "axis": { "type": "string" }
          }
        },
        "scatter": {
          "type": "object",
          "properties": {
            "count": { "type": "number" },
            "radius": { "type": "number" },
            "center": { "$ref": "#/definitions/vec3" },
            "height": { "type": "number" },
            "bounds": {},
            "seed": { "type": "number" },
            "randomRotation": { "type": "boolean" },
            "scaleVariation": { "type": "number" }
          }
        }
      }
    },
    "material": {
      "type": "object",
      "properties": {
        "preset": { "type": "string" },
        "color": { "type": ["string", "number"] },
        "metalness": { "type": "number" },
        "roughness": { "type": "number" },
        "emissive": { "type": ["string", "number"] },
        "emissiveIntensity": { "type": "number" },
        "flatShading": { "type": "boolean" },
        "opacity": { "type": "number" },
        "transparent": { "type": "boolean" },
        "side": { "type": "string" },
        "doubleSide": { "type": "boolean" },
        "envMapIntensity": { "type": "number" },
        "vertexColors": { "type": "boolean" },
        "clearcoat": { "type": "number" },
        "clearcoatRoughness": { "type": "number" },
        "transmission": { "type": "number" },
        "ior": { "type": "number" },
        "alphaTest": { "type": "number" },
        "breakup": {
          "type": "object",
          "properties": {
            "noise": { "type": "object" },
            "grime": { "type": "object" },
            "edgeWear": { "type": "object" },
            "roughnessVariation": { "type": ["number", "object"] }
          }
        },
        "decals": { "type": "array" },
        "emissiveStrips": { "type": ["object", "array"] }
      },
      "additionalProperties": true
    },
    "csgShape": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["box", "sphere", "cylinder", "cone", "torus", "capsule"] },
        "size": { "type": "array" },
        "radius": { "type": "number" },
        "radiusTop": { "type": "number" },
        "radiusBottom": { "type": "number" },
        "height": { "type": "number" },
        "tube": { "type": "number" },
        "length": { "type": "number" },
        "segments": { "type": "number" },
        "radialSegments": { "type": "number" },
        "tubularSegments": { "type": "number" },
        "capSegments": { "type": "number" },
        "position": { "$ref": "#/definitions/vec3" },
        "rotation": { "$ref": "#/definitions/vec3" }
      }
    },
    "csgOperation": {
      "type": "object",
      "required": ["op", "a", "b", "result"],
      "properties": {
        "op": { "enum": ["union", "subtract", "intersect", "add", "difference", "intersection"] },
        "a": { "type": "string" },
        "b": { "type": "string" },
        "result": { "type": "string" }
      }
    },
    "scene": {
      "type": "object",
      "properties": {
        "quality": { "enum": ["draft", "standard", "high"] },
        "background": {},
        "fog": { "type": "object" },
        "exposure": { "type": "number" },
        "toneMapping": { "enum": ["none", "linear", "reinhard", "cineon", "acesfilmic", "neutral",
          "None", "Linear", "Reinhard", "Cineon", "ACESFilmic", "Neutral"] },
        "quality_note": {},
        "floor": { "type": "object", "properties": { "visible": { "type": "boolean" } } },
        "ground": { "type": "object", "properties": { "reflective": { "type": "boolean" } } },
        "camera": {
          "type": "object",
          "properties": {
            "preset": { "enum": ["front", "back", "left", "right", "top", "threeQuarter", "lowAngle", "highAngle"] },
            "fit": { "type": "boolean" },
            "scaleToModel": { "type": "boolean" },
            "distanceMultiplier": { "type": "number" },
            "positionOffset": { "$ref": "#/definitions/vec3" },
            "targetOffset": { "$ref": "#/definitions/vec3" }
          }
        },
        "lighting": {
          "type": "object",
          "properties": {
            "preset": { "enum": ["studio", "sunset", "night", "overcast", "dramatic", "neon",
              "cyberpunk", "warm", "cool", "rim", "backlit", "goldenHour", "noir", "underwater",
              "horror", "industrialRuin", "showcase"] },
            "environment": { "enum": ["none", "studio", "outdoor", "sunset", "night"] },
            "envMapIntensity": { "type": "number" },
            "intensity": { "type": "number" },
            "shadowQuality": { "type": "string" }
          },
          "additionalProperties": true
        },
        "postfx": {
          "type": "object",
          "properties": {
            "ssao": {}, "dof": {}, "ssr": {}, "bloom": {}, "outline": {}, "pixel": {},
            "vignette": {}, "chromatic": {}, "grain": {}, "scanlines": {}, "colorGrade": {}, "fxaa": {}
          },
          "additionalProperties": true
        },
        "terrain": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}
