{
  "name": "landscape-example",
  "description": "Lowpoly forest ruin — adapted from scratchpad/lowpoly-example. Demonstrates the terrain compositor with category-tagged parts. Natural env (ground, cliffs, rocks) gets draped into a single mesh; the gateway is a structure and remains visible; trees, crystals, lantern, and figure are props and are rendered on top of the terrain. Toggle scene.terrain.display between 'primitives', 'terrain', and 'both' (or use the Terrain dropdown in the viewer).",
  "root": "scene_root",
  "scene": {
    "quality": "standard",
    "background": { "type": "gradient", "color": "#6a8090", "color2": "#2a3e4a" },
    "fog": { "type": "exp2", "color": "#3e5260", "density": 0.025 },
    "lighting": {
      "preset": "outdoor",
      "environment": "dusk",
      "envMapIntensity": 0.6,
      "shadowQuality": "high",
      "intensity": 1.3,
      "ambient": { "color": "#6a8090", "intensity": 0.5 },
      "directional": { "color": "#ffe8d0", "intensity": 1.6, "position": [3, 8, 6] },
      "hemisphere": { "skyColor": "#9ab4c4", "groundColor": "#3a4a54", "intensity": 1.1 }
    },
    "ground": { "reflective": false },
    "exposure": 1.35,
    "toneMapping": "ACESFilmic",
    "camera": {
      "preset": "threeQuarter",
      "fov": 32,
      "distanceMultiplier": 1.1,
      "positionOffset": [2.0, 1.8, 3.5],
      "targetOffset": [0, 1.0, 0]
    },
    "postfx": {
      "bloom": { "enabled": true, "strength": 0.45, "radius": 0.6, "threshold": 0.9 },
      "vignette": { "enabled": true, "intensity": 0.15, "softness": 0.7 },
      "colorGrade": { "enabled": true, "saturation": 1.0, "brightness": 1.05, "contrast": 1.05 },
      "fxaa": true
    },
    "terrain": {
      "enabled": true,
      "method": "heightfield",
      "display": "terrain",
      "flipNormals": true,
      "bounds": "auto",
      "resolution": 96,
      "smoothing": 0.35,
      "variableResolution": { "enabled": false, "highDensityRadius": 3.0, "lowDensityFactor": 0.25 },
      "material": { "color": "#506874", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "methodOptions": {
        "heightfield": { "padding": 0.75, "skirt": 3.0 },
        "marchingCubes": { "isoLevel": 0.0, "smoothingRadius": 0.25 },
        "clothDrape": { "iterations": 60, "stiffness": 0.8, "gravity": -9.8 }
      }
    }
  },
