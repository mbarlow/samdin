{
  "name": "landscape-stress",
  "description": "Stress-test for the terrain compositor. Rolling hills, a valley with a riverbed, a shoreline with water plane, scattered rock clusters, a cliff edge, and a ruined structure. Uses a larger bounds (~32x32) and higher resolution than landscape-example to exercise raycasting and memory. All natural primitives are category: \"environment\"; the ruin is category: \"structure\"; trees and props float above on top of the terrain.",
  "root": "scene_root",
  "scene": {
    "quality": "standard",
    "background": { "type": "gradient", "color": "#8ca8ba", "color2": "#3a5260" },
    "fog": { "type": "exp2", "color": "#6a8090", "density": 0.018 },
    "lighting": {
      "preset": "outdoor",
      "environment": "dusk",
      "envMapIntensity": 0.5,
      "shadowQuality": "high",
      "intensity": 1.3,
      "ambient": { "color": "#7a94a6", "intensity": 0.55 },
      "directional": { "color": "#ffe6c4", "intensity": 1.5, "position": [8, 14, 5] },
      "hemisphere": { "skyColor": "#a6c0cc", "groundColor": "#3e4a52", "intensity": 1.0 }
    },
    "ground": { "reflective": false },
    "exposure": 1.3,
    "toneMapping": "ACESFilmic",
    "camera": {
      "preset": "highAngle",
      "fov": 38,
      "distanceMultiplier": 1.6,
      "positionOffset": [6, 8, 10],
      "targetOffset": [0, 0.5, 0]
    },
    "postfx": {
      "bloom": { "enabled": true, "strength": 0.35, "radius": 0.5, "threshold": 0.92 },
      "vignette": { "enabled": true, "intensity": 0.12, "softness": 0.6 },
      "colorGrade": { "enabled": true, "saturation": 1.02, "brightness": 1.05, "contrast": 1.03 },
      "fxaa": true
    },
    "terrain": {
      "enabled": true,
      "method": "heightfield",
      "display": "terrain",
      "bounds": [-18, -18, 18, 18],
      "resolution": 160,
      "smoothing": 0.45,
      "variableResolution": { "enabled": false, "highDensityRadius": 4.0, "lowDensityFactor": 0.4 },
      "material": { "color": "#5c7080", "metalness": 0.0, "roughness": 0.92, "flatShading": true },
      "methodOptions": {
        "heightfield": { "padding": 1.0, "skirt": 4.0 },
        "marchingCubes": { "isoLevel": 0.0, "smoothingRadius": 0.3 },
        "clothDrape": { "iterations": 80, "stiffness": 0.75, "gravity": -9.8 }
      }
    }
  },
