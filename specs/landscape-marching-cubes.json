{
  "name": "landscape-marching-cubes",
  "description": "Marching-cubes terrain demo. Env-tagged boulders and cliff chunks are overlapped and stacked so the density field produces a single draped mesh with overhangs and fused silhouettes. Toggle scene.terrain.display to compare the raw primitives against the generated iso-surface.",
  "root": "scene_root",
  "scene": {
    "quality": "standard",
    "background": { "type": "gradient", "color": "#6a8090", "color2": "#1e2a34" },
    "fog": { "type": "exp2", "color": "#3e5260", "density": 0.02 },
    "lighting": {
      "preset": "outdoor",
      "environment": "dusk",
      "envMapIntensity": 0.55,
      "shadowQuality": "high",
      "intensity": 1.2,
      "ambient": { "color": "#6a8090", "intensity": 0.45 },
      "directional": { "color": "#ffe4c8", "intensity": 1.6, "position": [4, 9, 5] },
      "hemisphere": { "skyColor": "#9ab4c4", "groundColor": "#36424c", "intensity": 1.0 }
    },
    "ground": { "reflective": false },
    "exposure": 1.3,
    "toneMapping": "ACESFilmic",
    "camera": {
      "preset": "threeQuarter",
      "fov": 34,
      "distanceMultiplier": 1.15,
      "positionOffset": [2.5, 2.0, 4.0],
      "targetOffset": [0, 0.8, 0]
    },
    "postfx": {
      "bloom": { "enabled": true, "strength": 0.4, "radius": 0.6, "threshold": 0.9 },
      "vignette": { "enabled": true, "intensity": 0.15, "softness": 0.7 },
      "colorGrade": { "enabled": true, "saturation": 1.0, "brightness": 1.05, "contrast": 1.05 },
      "fxaa": true
    },
    "terrain": {
      "enabled": true,
      "method": "marching-cubes",
      "display": "terrain",
      "bounds": "auto",
      "resolution": 48,
      "smoothing": 0.35,
      "material": { "color": "#52636e", "metalness": 0.0, "roughness": 0.92, "flatShading": true },
      "methodOptions": {
        "marchingCubes": { "padding": 0.75, "isoLevel": 0.5, "smoothingPasses": 1 }
      }
    }
  },
  "parts": [
    { "name": "scene_root", "type": "group", "position": [0, 0, 0] },

    { "name": "ground", "type": "group", "parent": "scene_root", "category": "environment" },
    {
      "name": "ground_slab",
      "type": "box",
      "params": [10, 0.4, 10],
      "material": { "color": "#4c5c68", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [0, -0.2, 0],
      "parent": "ground",
      "category": "environment",
      "receiveShadow": true
    },

    { "name": "rocks", "type": "group", "parent": "scene_root", "category": "environment" },
    {
      "name": "boulder_a",
      "type": "sphere",
      "params": [1.4, 1],
      "material": { "color": "#586772", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [-1.8, 0.8, 0.4],
      "scale": [1.3, 0.9, 1.1],
      "parent": "rocks",
      "category": "environment"
    },
    {
      "name": "boulder_b",
      "type": "sphere",
      "params": [1.1, 1],
      "material": { "color": "#5a6b77", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [-0.4, 1.5, -0.2],
      "scale": [1.2, 1.0, 1.0],
      "parent": "rocks",
      "category": "environment"
    },
    {
      "name": "boulder_c",
      "type": "sphere",
      "params": [1.2, 1],
      "material": { "color": "#556673", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [1.4, 0.9, 0.1],
      "scale": [1.1, 0.95, 1.2],
      "parent": "rocks",
      "category": "environment"
    },
    {
      "name": "overhang",
      "type": "box",
      "params": [3.6, 0.6, 1.4],
      "material": { "color": "#52636e", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [-0.2, 2.2, -0.3],
      "rotation": [0, 8, -4],
      "parent": "rocks",
      "category": "environment"
    },
    {
      "name": "cliff_back",
      "type": "box",
      "params": [8, 2.4, 1.6],
      "material": { "color": "#4a5a66", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [0, 1.0, -3.2],
      "rotation": [0, 3, 0],
      "parent": "rocks",
      "category": "environment"
    },
    {
      "name": "cliff_back_cap",
      "type": "sphere",
      "params": [0.9, 1],
      "material": { "color": "#52626d", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [-2.2, 2.2, -3.0],
      "scale": [1.4, 0.8, 1.2],
      "parent": "rocks",
      "category": "environment"
    },
    {
      "name": "cliff_back_cap_b",
      "type": "sphere",
      "params": [0.8, 1],
      "material": { "color": "#52626d", "metalness": 0.0, "roughness": 0.9, "flatShading": true },
      "position": [2.4, 2.3, -3.1],
      "scale": [1.3, 0.8, 1.2],
      "parent": "rocks",
      "category": "environment"
    },

    {
      "name": "gateway",
      "type": "prefab",
      "src": "broken-column",
      "position": [2.0, 0.5, 1.2],
      "rotation": [0, 20, 0],
      "scale": [0.9, 1.1, 0.9]
    },
    {
      "name": "lantern",
      "type": "prefab",
      "src": "japanese-lantern",
      "position": [-2.8, 0.5, 2.2],
      "scale": [0.7, 0.7, 0.7]
    }
  ]
}
